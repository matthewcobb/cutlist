{
  "name": "cutlist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev web",
    "build": "nuxt build web",
    "build:static": "nuxt generate web",
    "preview": "nuxt preview web",
    "lint": "prettier --check .",
    "check": "cd web && vue-tsc --noEmit",
    "test": "bun test web/",
    "test:watch": "bun test --watch web/",
    "postinstall": "nuxt prepare web",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/ri": "^1.2.10",
    "@sentry/nuxt": "^10",
    "idb": "^8.0.3",
    "js-yaml": "^4.1.0",
    "panzoom": "^9.4.4",
    "pdf-lib": "^1.17.1",
    "three": "^0.184.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nuxt/ui": "^3.0.0",
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "@types/three": "^0.184.0",
    "@vueuse/core": "^14.0.0",
    "@vueuse/nuxt": "^14.0.0",
    "fake-indexeddb": "^6.2.5",
    "lint-staged": "^15.5.2",
    "nuxt": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.0",
    "vue": "^3.4.21",
    "vue-router": "^5.0.0",
    "vue-tsc": "^3.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "overrides": {
    "cross-spawn": "^7.0.6"
  }
}
