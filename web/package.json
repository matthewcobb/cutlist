{
  "name": "cutlist",
  "version": "1.0.9",
  "type": "module",
  "scripts": {
    "check": "vue-tsc --noEmit",
    "dev": "nuxt dev",
    "build": "bun build:nuxt && bun build:docker",
    "build:nuxt": "nuxt build",
    "build:docker": "docker build . -t cutlist --platform=linux/amd64",
    "preview:web": "nuxt preview",
    "preview:web:docker": "docker run -it -p 3000:3000 --env-file .env cutlist",
    "publish:web:docker": "bun run build && docker push cutlist",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.28.4",
    "zod": "^3.22.4",
    "@types/three": "^0.184.0",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.0",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@nuxt/ui": "^2.14.2",
    "@types/js-yaml": "^4.0.9",
    "@vueuse/core": "^10.9.0",
    "@vueuse/nuxt": "^10.9.0",
    "drizzle-kit": "^0.31.10",
    "nuxt": "^3.11.0",
    "typescript": "^5.0.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  }
}
